{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ioc-hash.schema.json",
  "title": "IOC Hash Entries",
  "description": "Schema for SkillLedger IOC hash indicator entries",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["sha256", "description", "severity", "source", "reported_at"],
    "additionalProperties": false,
    "properties": {
      "sha256": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$",
        "description": "SHA-256 hash of the malicious artifact"
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "description": "Human-readable description of the threat"
      },
      "severity": {
        "type": "string",
        "enum": ["critical", "high", "medium", "low", "info"],
        "description": "Severity level of the indicator"
      },
      "source": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255,
        "description": "Attribution source for this indicator"
      },
      "reported_at": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "Date the indicator was reported (YYYY-MM-DD)"
      }
    }
  }
}
