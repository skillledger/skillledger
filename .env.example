# =====================================================================
# SkillLedger - Environment Variables (self-hosted)
# =====================================================================
# Copy this file to .env and fill in real values before starting the
# stack. Never commit .env to version control.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env, then:
#   docker compose up -d                                              # dev
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     up -d                                                           # prod (with Caddy TLS)
#
# Generate a strong random secret:
#   openssl rand -base64 32


# =====================================================================
# Core service - REQUIRED
# =====================================================================

# PostgreSQL credentials (used by docker-compose, service, and Alembic)
POSTGRES_PASSWORD=                              # required - DB password (openssl rand -base64 32)
POSTGRES_USER=skillledger                       # default: skillledger
POSTGRES_DB=skillledger                         # default: skillledger
# Async DB URL consumed by the FastAPI service. Override only if running
# Postgres outside docker-compose.
# SKILLLEDGER_DATABASE_URL=postgresql+asyncpg://skillledger:${POSTGRES_PASSWORD}@db:5432/skillledger

# Admin API key for publisher management endpoints (/publishers, /publishers/{id}/keys)
SKILLLEDGER_ADMIN_API_KEY=                      # required - openssl rand -base64 32

# JWT signing secret for user auth (HS256)
SKILLLEDGER_JWT_SECRET=                         # required - openssl rand -base64 32

# Transparency log signing key (Ed25519 private key, base64-encoded DER).
# Generate: openssl genpkey -algorithm Ed25519 -outform DER | base64
LOG_PRIVATE_KEY=                                # required - Ed25519 private key (DER, base64)


# =====================================================================
# Domains - REQUIRED for production (Caddy TLS)
# =====================================================================
# Point these DNS A records to the host running docker compose before
# starting the production overlay. Caddy provisions Let's Encrypt certs
# automatically on first hit.

SKILLLEDGER_DOMAIN=api.skillledger.in           # API + transparency log service
DASHBOARD_DOMAIN=app.skillledger.in             # Dashboard (Next.js)
SKILLLEDGER_DASHBOARD_URL=https://app.skillledger.in   # full dashboard URL (used by SAML ACS redirects)
# Allowed CORS origins (JSON array, parsed by Pydantic).
SKILLLEDGER_CORS_ORIGINS=["https://app.skillledger.in"]


# =====================================================================
# Email / OTP delivery (Resend)
# =====================================================================
# Required for user OTP login (Phase 18). Get an API key at https://resend.com
SKILLLEDGER_RESEND_API_KEY=                     # Resend API key for OTP email delivery
# From address used for OTP emails. Verify the domain in Resend first.
# Default: SkillLedger <noreply@skillledger.in>


# =====================================================================
# Billing (Stripe)
# =====================================================================
# Required only if you want to enable hosted-compute billing or
# per-seat Enterprise billing. Get keys at https://dashboard.stripe.com
SKILLLEDGER_STRIPE_SECRET_KEY=                  # Stripe secret key (sk_test_... or sk_live_...)
SKILLLEDGER_STRIPE_WEBHOOK_SECRET=              # Stripe webhook signing secret (whsec_...)
SKILLLEDGER_STRIPE_PRICE_ID=                    # Pay-as-you-go price ID (price_...)
SKILLLEDGER_STRIPE_SEAT_PRICE_ID=               # Per-seat subscription price ID (price_...) - EE only


# =====================================================================
# Enterprise Edition (EE) license gating
# =====================================================================
# Required only when running the proprietary Enterprise routers under
# service/src/skillledger_service/ee/. Contact sales@skillledger.in for
# a license key, or leave blank to disable EE routers.
SKILLLEDGER_EE_LICENSE_KEY=                     # EE license key (signed token)
SKILLLEDGER_EE_LICENSE_HASH=                    # optional - precomputed SHA-256 of license key


# =====================================================================
# Service-side runtime tuning - OPTIONAL
# =====================================================================
# SKILLLEDGER_DEBUG=false                       # verbose logging
# SKILLLEDGER_LOG_URL=https://api.skillledger.in        # explicit log endpoint (default = same host)
# SKILLLEDGER_SERVICE_URL=https://api.skillledger.in    # explicit service URL


# =====================================================================
# Dashboard (Next.js / Auth.js)
# =====================================================================
# See dashboard/.env.local.example for the full dashboard-local variant.
AUTH_SECRET=                                    # required - session encryption (openssl rand -base64 32)
AUTH_URL=https://app.skillledger.in             # canonical dashboard URL (Auth.js)
# AUTH_TRUST_HOST=true                          # set when running behind a reverse proxy (Caddy)
NEXT_PUBLIC_API_URL=https://api.skillledger.in  # public API base URL (exposed to browser)
API_URL=https://api.skillledger.in              # server-side API base URL (SSR)


# =====================================================================
# CLI-side variables (set in your shell, not in this file)
# =====================================================================
# The following are read by the `skillledger` CLI on developer machines.
# They are documented here so you know what to set when running locally
# or in CI; they do NOT belong in docker-compose .env.
#
#   SKILLLEDGER_API_KEY            - Publisher API key for publish
#   SKILLLEDGER_SERVICE_URL        - Override service URL (defaults to https://api.skillledger.in)
#   SKILLLEDGER_HOME               - Override CLI data dir (default ~/.skillledger)
#   SKILLLEDGER_PROXY_PORT         - Proxy listen port (default 8888)
#   SKILLLEDGER_ALLOW_HTTP         - Allow plaintext HTTP to service (dev only)
#   SKILLLEDGER_NO_UPDATE_CHECK    - Disable update check
#   SIGSTORE_ID_TOKEN              - OIDC token for keyless signing (set by CI)
#   SOURCE_DATE_EPOCH              - Reproducible-build timestamp (set by CI)
