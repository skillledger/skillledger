# SkillLedger Self-Hosted Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d                                    # Development
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d  # Production

# === Required ===
POSTGRES_PASSWORD=           # Database password (generate: openssl rand -base64 32)
SKILLLEDGER_ADMIN_API_KEY=   # Admin API key for publisher management (generate: openssl rand -base64 32)
AUTH_SECRET=                 # Dashboard session encryption key (generate: openssl rand -base64 32)
LOG_PRIVATE_KEY=             # Transparency log signing key (Ed25519 private key, base64-encoded DER)
                             # Generate: openssl genpkey -algorithm Ed25519 -outform DER | base64 -w0

# === Required for Production (Caddy TLS) ===
# Set these and ensure DNS A records point to your server IP
SKILLLEDGER_DOMAIN=log.skillledger.dev       # API/log service domain
DASHBOARD_DOMAIN=dashboard.skillledger.dev   # Dashboard domain

# === Optional (have sensible defaults) ===
POSTGRES_USER=skillledger    # Database user (default: skillledger)
POSTGRES_DB=skillledger      # Database name (default: skillledger)
