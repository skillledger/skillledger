{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillledger.in/schemas/v0.1/capabilities.schema.json",
  "title": "Capability Manifest",
  "description": "Declares permissions the skill requires. Undeclared capabilities are denied.",
  "type": "object",
  "properties": {
    "filesystem": {
      "type": "array",
      "items": {
        "type": "string",
        "allOf": [
          { "pattern": "^(read|write)(:.+)?$" },
          { "not": { "pattern": "\\.\\." } }
        ]
      },
      "maxItems": 100,
      "description": "Filesystem permissions (e.g., read, write:./data)"
    },
    "network": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(outbound|inbound)(:.+)?$"
      },
      "maxItems": 100,
      "description": "Network permissions (e.g., outbound:*.openai.com)"
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "string",
        "allOf": [
          { "pattern": "^(env|file|vault)(:.+)?$" },
          { "not": { "pattern": "\\.\\." } }
        ]
      },
      "maxItems": 100,
      "description": "Secrets access (e.g., env:API_KEY, file:/etc/secret)"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(execute)(:.+)?$"
      },
      "maxItems": 50,
      "description": "Tool execution (e.g., execute:bash, execute:python)"
    }
  },
  "additionalProperties": false
}
