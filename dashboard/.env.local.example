# =====================================================================
# Dashboard (Next.js + Auth.js) - LOCAL development env
# =====================================================================
# Copy to dashboard/.env.local. Never commit .env.local.
#
# For production values (https://app.skillledger.in), see the root
# .env.example - those are injected into the container by docker-compose.

# Auth.js
AUTH_SECRET=                          # required - openssl rand -base64 32
AUTH_URL=http://localhost:3000        # canonical dashboard URL
# AUTH_TRUST_HOST=true                # uncomment when behind a reverse proxy (Caddy / nginx)

# API endpoints
NEXT_PUBLIC_API_URL=http://localhost:8000   # browser-exposed API base
API_URL=http://localhost:8000               # server-side API base (SSR / route handlers)

# SAML (optional - SSO testing)
# No extra config needed. SAML is driven per-org by
# /ee/v1/saml/{slug}/login on the service.
